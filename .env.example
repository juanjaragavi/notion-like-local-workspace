# =============================================================================
# Notion Workspace - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control
#
# Vercel deployment:
#   Add all variables below in your Vercel project → Settings → Environment
#   Variables.  Set NEXTAUTH_URL to your production URL (e.g.
#   https://your-app.vercel.app).  VERCEL_URL is set automatically by Vercel
#   and is used as a fallback when NEXTAUTH_URL is absent.
# =============================================================================

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"
# Set to your deployed URL on Vercel (e.g. https://your-app.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: openid, email, profile, gmail.readonly, drive.readonly,
#   documents.readonly, calendar.readonly
# Add your Vercel domain to "Authorized redirect URIs":
#   https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional — override the OAuth redirect URI (auto-derived from NEXTAUTH_URL if unset)
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# --- PostgreSQL / Cloud SQL ---
#
# The app supports two connection modes; pick ONE:
#
# MODE A — Cloud SQL Connector (recommended for both local and Vercel)
#   No proxy binary needed. The @google-cloud/cloud-sql-connector npm package
#   opens an mTLS tunnel inside the Node.js process using IAM authentication.
#
#   Local dev pre-requisite (one-time):
#     gcloud auth application-default login
#
#   Required vars:
CLOUD_SQL_CONNECTION_NAME="absolute-brook-452020-d5:us-central1:notion-workspace-db"
# For built-in users (e.g. 'postgres'): set both USER and PASS.
# For IAM DB users: set USER to the IAM email, leave PASS empty/unset.
CLOUD_SQL_DB_USER="postgres"
CLOUD_SQL_DB_PASS=""
CLOUD_SQL_DB_NAME="postgres"
#
#   On Vercel, also set one of:
#     GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json   (file path)
#     GOOGLE_APPLICATION_CREDENTIALS_JSON='{...}'           (raw JSON, single line)
#
# MODE B — Direct DATABASE_URL (Neon / Supabase / local Postgres / proxy)
#   Only used when CLOUD_SQL_CONNECTION_NAME is NOT set.
# DATABASE_URL="postgresql://user:password@localhost:5432/notion_workspace"

# --- Google Gemini AI ---
# Get API key from: https://aistudio.google.com/apikey
# Required for the AI Agent workspace assistant
GEMINI_API_KEY=""

