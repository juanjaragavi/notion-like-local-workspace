# =============================================================================
# Notion Workspace - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control
# =============================================================================

# --- NextAuth.js ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
# Required scopes: openid, email, profile, gmail.readonly, calendar.readonly
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# --- PostgreSQL Database ---
# Connection string for PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/notion_workspace"

# --- Google Gemini AI ---
# Get API key from: https://aistudio.google.com/apikey
# Required for the AI Agent workspace assistant
GEMINI_API_KEY=""
